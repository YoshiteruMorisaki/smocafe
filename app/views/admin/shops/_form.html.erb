<%= form_with model: [:admin, shop], class: "row g-4" do |form| %>
  <div class="col-12">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", required: true %>
  </div>

  <div class="col-md-6">
    <%= form.label :area, class: "form-label" %>
    <%= form.select :area, Shop::AREAS, {}, class: "form-select", required: true %>
  </div>

  <div class="col-md-6">
    <%= form.label :address, class: "form-label" %>
    <%= form.text_field :address, class: "form-control", required: true %>
  </div>

  <div class="col-md-6">
    <%= form.label :business_hours, class: "form-label" %>
    <%= form.text_field :business_hours, class: "form-control" %>
  </div>

  <div class="col-md-6">
    <%= form.label :closed_days, class: "form-label" %>
    <%= form.text_field :closed_days, class: "form-control" %>
  </div>

  <div class="col-md-6">
    <%= form.label :heated_tobacco_status, class: "form-label" %>
    <%= form.select :heated_tobacco_status, Shop.heated_tobacco_statuses.keys.map { |key| [Shop.human_enum_name(:heated_tobacco_status, key), key] }, {}, class: "form-select" %>
  </div>

  <div class="col-md-6">
    <%= form.label :papper_tobacco_status, class: "form-label" %>
    <%= form.select :papper_tobacco_status, Shop.papper_tobacco_statuses.keys.map { |key| [Shop.human_enum_name(:papper_tobacco_status, key), key] }, {}, class: "form-select" %>
  </div>

  <div class="col-md-6">
    <%= form.label :last_reported_at, class: "form-label" %>
    <%= form.datetime_local_field :last_reported_at, class: "form-control" %>
  </div>

  <div class="col-md-3">
    <div class="form-check mt-md-4 pt-md-2">
      <%= form.check_box :wifi_available, class: "form-check-input" %>
      <%= form.label :wifi_available, class: "form-check-label" %>
    </div>
  </div>

  <div class="col-md-3">
    <div class="form-check mt-md-4 pt-md-2">
      <%= form.check_box :power_available, class: "form-check-input" %>
      <%= form.label :power_available, class: "form-check-label" %>
    </div>
  </div>

  <div class="col-12">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, class: "form-control", rows: 5 %>
  </div>

  <div class="col-12">
    <%= form.label :tag_ids, "タグ", class: "form-label" %>
    <div class="border rounded-3 p-3 bg-light-subtle">
      <% if @tags.any? %>
        <div class="row g-2">
          <%= form.collection_check_boxes :tag_ids, @tags, :id, :name do |builder| %>
            <div class="col-sm-6 col-lg-4">
              <label class="form-check border rounded-3 bg-white px-3 py-2 h-100 d-flex align-items-center gap-2">
                <%= builder.check_box class: "form-check-input mt-0" %>
                <span class="form-check-label"><%= builder.text %></span>
              </label>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mb-0 text-secondary">タグがまだ登録されていません。先にタグ管理から作成してください。</p>
      <% end %>
    </div>
  </div>

  <div class="col-12">
    <%= form.label :image, class: "form-label" %>
    <%= form.file_field :image, class: "form-control", accept: "image/*" %>
    <div class="form-text">未設定の場合は No_image.jpg を表示します。</div>
  </div>

  <% if shop.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger mb-0">
        <p class="fw-semibold mb-2">入力内容を確認してください。</p>
        <ul class="mb-0 ps-3">
          <% shop.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="col-12 d-flex gap-2">
    <%= form.submit(form.object.persisted? ? "店舗を更新する" : "店舗を作成する", class: "btn btn-primary") %>
    <%= link_to admin_shops_path, class: "btn btn-outline-secondary" do %>
      戻る
    <% end %>
  </div>
<% end %>
