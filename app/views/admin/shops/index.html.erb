<% content_for :title, "Smocafe Admin | 店舗管理" %>

<div class="container py-5">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h2 mb-1">店舗管理</h1>
      <p class="text-secondary mb-0">掲載店舗の登録・編集・削除を行います。</p>
    </div>
    <%= link_to new_admin_shop_path, class: "btn btn-primary" do %>
      <i class="fa-solid fa-plus me-1"></i>新規店舗を追加
    <% end %>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>店舗名</th>
            <th>エリア</th>
            <th>電子</th>
            <th>紙</th>
            <th>最終更新</th>
            <th class="text-end">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @shops.each do |shop| %>
            <tr>
              <td>
                <div class="fw-semibold"><%= shop.name %></div>
                <div class="small text-secondary"><%= shop.address %></div>
              </td>
              <td><%= shop.area %></td>
              <td><%= shop.heated_tobacco_status_i18n %></td>
              <td><%= shop.papper_tobacco_status_i18n %></td>
              <td><%= shop.last_reported_at.present? ? l(shop.last_reported_at, format: :short) : "未登録" %></td>
              <td>
                <div class="d-flex justify-content-end gap-2">
                  <%= link_to edit_admin_shop_path(shop), class: "btn btn-sm btn-outline-primary" do %>
                    編集
                  <% end %>
                  <%= link_to admin_shop_path(shop), class: "btn btn-sm btn-outline-danger", data: { turbo_method: :delete, turbo_confirm: "#{shop.name}を削除しますか？" } do %>
                    削除
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%= render "shared/pagination", collection: @shops %>
</div>
