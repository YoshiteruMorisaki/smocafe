<%= form_with model: [:admin, tag], class: "row g-4" do |form| %>
  <div class="col-12">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: "例: Wi-Fi / 深夜営業 / 静か", required: true %>
  </div>

  <% if tag.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger mb-0">
        <p class="fw-semibold mb-2">入力内容を確認してください。</p>
        <ul class="mb-0 ps-3">
          <% tag.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="col-12 d-flex gap-2">
    <%= form.submit(form.object.persisted? ? "タグを更新する" : "タグを作成する", class: "btn btn-success") %>
    <%= link_to admin_tags_path, class: "btn btn-outline-secondary" do %>
      戻る
    <% end %>
  </div>
<% end %>
