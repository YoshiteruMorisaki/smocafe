<% content_for :title, "Smocafe | トップ" %>

<section
  class="top-hero d-flex align-items-center"
  style="background-image: linear-gradient(90deg, rgba(248, 240, 228, 0.88) 0%, rgba(248, 240, 228, 0.72) 36%, rgba(97, 68, 49, 0.18) 100%), url('<%= asset_path("top_bg.jpg") %>');"
>
  <div class="container py-3 py-lg-4">
    <div class="row align-items-center g-4 g-xl-5 top-hero__inner">
      <div class="col-lg-7 col-xl-6">
        <div class="top-hero__copy pe-xl-4">
          <p class="top-hero__brand mb-2">Smocafe</p>
          <h1 class="top-hero__headline mb-3">
            喫煙可能なカフェ探しを、<br>
            もっとスマートに。
          </h1>
          <p class="top-hero__description mb-0">
            Smocafeは、喫煙可能なカフェやひと息つける空間を見つけやすくするカフェ検索サービスです。
            気になるエリアや今いる場所から、使いやすい一軒をすばやく探せます。
          </p>
        </div>
      </div>

      <div class="col-lg-5 col-xl-5 ms-lg-auto">
        <div class="d-grid gap-2 top-hero__actions">
          <%= link_to root_path, class: "btn top-hero__action-btn" do %>
            <span class="top-hero__action-icon">
              <i class="fa-solid fa-map-location-dot"></i>
            </span>
            <span class="top-hero__action-label">エリアから探す</span>
          <% end %>

          <%= link_to root_path, class: "btn top-hero__action-btn" do %>
            <span class="top-hero__action-icon">
              <i class="fa-solid fa-location-crosshairs"></i>
            </span>
            <span class="top-hero__action-label">現在地から探す</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
