<% content_for :title, "Smocafe | 新規登録" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
          <div class="text-center mb-4">
            <div class="fs-1 text-success mb-2"><i class="fa-solid fa-user-plus"></i></div>
            <h1 class="h3 mb-1">新規会員登録</h1>
            <p class="text-secondary mb-0">Smocafe を利用するためのアカウントを作成します。</p>
          </div>

          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <p class="fw-semibold mb-2">入力内容をご確認ください。</p>
              <ul class="mb-0 ps-3">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @user, url: users_path do |f| %>
            <div class="row g-3">
              <div class="col-12">
                <%= f.label :name, "表示名", class: "form-label" %>
                <%= f.text_field :name, class: "form-control", placeholder: "スモカフェ太郎", required: true %>
              </div>

              <div class="col-12">
                <%= f.label :email_address, "メールアドレス", class: "form-label" %>
                <%= f.email_field :email_address, class: "form-control", placeholder: "example@smocafe.jp", required: true %>
              </div>

              <div class="col-md-6">
                <%= f.label :password, "パスワード", class: "form-label" %>
                <%= f.password_field :password, class: "form-control", placeholder: "6文字以上" %>
              </div>

              <div class="col-md-6">
                <%= f.label :password_confirmation, "パスワード確認", class: "form-label" %>
                <%= f.password_field :password_confirmation, class: "form-control", placeholder: "再入力" %>
              </div>
            </div>

            <div class="d-grid mt-4">
              <%= f.submit "会員登録する", class: "btn btn-success btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
