<% content_for :title, "Smocafe | ログイン" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
          <div class="text-center mb-4">
            <div class="fs-1 text-success mb-2"><i class="fa-solid fa-right-to-bracket"></i></div>
            <h1 class="h3 mb-1">ログイン</h1>
            <p class="text-secondary mb-0">登録済みのアカウントでサインインしてください。</p>
          </div>

          <%= form_with url: users_sign_in_path do %>
            <div class="mb-3">
              <%= label_tag :email_address, "メールアドレス", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fa-regular fa-envelope"></i></span>
                <%= email_field_tag :email_address, @email_address, class: "form-control", placeholder: "example@smocafe.jp", required: true %>
              </div>
            </div>

            <div class="mb-4">
              <%= label_tag :password, "パスワード", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                <%= password_field_tag :password, nil, class: "form-control", placeholder: "6文字以上", required: true %>
              </div>
            </div>

            <div class="d-grid mb-3">
              <%= submit_tag "ログイン", class: "btn btn-success btn-lg" %>
            </div>
          <% end %>

          <p class="text-center text-secondary mb-0">
            アカウントをお持ちでない方は
            <%= link_to "新規登録", users_sign_up_path, class: "link-success fw-semibold" %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
