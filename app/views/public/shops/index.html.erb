<% content_for :title, "Smocafe | 店舗一覧" %>

<div class="container py-5">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h2 mb-1">喫煙可能なカフェ一覧</h1>
      <p class="text-secondary mb-0">エリアや喫煙可否を見ながら店舗情報を確認できます。</p>
    </div>
    <div class="text-secondary small">
      登録店舗数: <span class="fw-semibold text-dark"><%= @shops.size %></span>
    </div>
  </div>

  <div class="row g-4">
    <% @shops.each do |shop| %>
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
          <%= image_tag shop.display_image, class: "card-img-top", alt: shop.name, style: "height: 220px; object-fit: cover;" %>
          <div class="card-body p-4 d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
              <div>
                <p class="text-success fw-semibold small mb-1"><%= shop.area %></p>
                <h2 class="h4 mb-1"><%= shop.name %></h2>
                <p class="text-secondary mb-0"><i class="fa-solid fa-location-dot me-1"></i><%= shop.address %></p>
              </div>
              <span class="badge text-bg-light border"><%= l(shop.last_reported_at, format: :short) if shop.last_reported_at.present? %></span>
            </div>

            <div class="d-flex flex-wrap gap-2 mb-3">
              <span class="badge text-bg-success-subtle text-success-emphasis">電子: <%= shop.heated_tobacco_status_i18n %></span>
              <span class="badge text-bg-warning-subtle text-warning-emphasis">紙: <%= shop.papper_tobacco_status_i18n %></span>
              <span class="badge text-bg-info-subtle text-info-emphasis">Wi-Fi: <%= shop.wifi_available? ? "あり" : "なし" %></span>
              <span class="badge text-bg-secondary">電源: <%= shop.power_available? ? "あり" : "なし" %></span>
            </div>

            <dl class="row small text-secondary mb-3">
              <dt class="col-sm-4">営業時間</dt>
              <dd class="col-sm-8"><%= shop.business_hours.presence || "未登録" %></dd>
              <dt class="col-sm-4">定休日</dt>
              <dd class="col-sm-8"><%= shop.closed_days.presence || "未登録" %></dd>
            </dl>

            <p class="text-secondary flex-grow-1 mb-4"><%= truncate(shop.description.to_s, length: 110) %></p>

            <%= link_to shop_path(shop), class: "btn btn-outline-success mt-auto align-self-start" do %>
              <i class="fa-solid fa-store me-1"></i>詳細を見る
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
