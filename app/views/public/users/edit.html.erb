<% content_for :title, "Smocafe | 会員情報編集" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
          <h1 class="h3 mb-3">会員情報編集</h1>
          <p class="text-secondary">名前やメールアドレス、必要に応じてパスワードを更新できます。</p>

          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <ul class="mb-0 ps-3">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @user, url: users_path, method: :patch do |f| %>
            <div class="row g-3">
              <div class="col-12">
                <%= f.label :name, "表示名", class: "form-label" %>
                <%= f.text_field :name, class: "form-control", required: true %>
              </div>

              <div class="col-12">
                <%= f.label :email_address, "メールアドレス", class: "form-label" %>
                <%= f.email_field :email_address, class: "form-control", required: true %>
              </div>

              <div class="col-md-6">
                <%= f.label :password, "新しいパスワード", class: "form-label" %>
                <%= f.password_field :password, class: "form-control", placeholder: "変更しない場合は空欄" %>
              </div>

              <div class="col-md-6">
                <%= f.label :password_confirmation, "パスワード確認", class: "form-label" %>
                <%= f.password_field :password_confirmation, class: "form-control", placeholder: "確認用" %>
              </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-4">
              <%= f.submit "更新する", class: "btn btn-success" %>
              <%= link_to "マイページへ戻る", users_my_page_path, class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
